TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_CHAT_IDS=your-chat-id
WORDPRESS_SITE_URL=https://your-wordpress-site.com
WORDPRESS_USERNAME=your-wordpress-username
WORDPRESS_PASSWORD=your-wordpress-application-password
WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SSL_NO_VERIFY=false

# Notion -> WooCommerce
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Site Kit / GA4 / Search Console
# Cach 1 khuyen dung neu GA4 khong nhan service account: OAuth Gmail.
GOOGLE_AUTH_MODE=oauth
GOOGLE_OAUTH_CLIENT_SECRET_JSON=google-oauth-client.json
GOOGLE_OAUTH_TOKEN_JSON=google-oauth-token.json

# Cach 2: service account, chi dung neu GA4/Search Console cho cap quyen truc tiep.
GOOGLE_SERVICE_ACCOUNT_JSON=google-service-account.json
GA4_PROPERTY_ID=123456789
GSC_SITE_URL=https://your-wordpress-site.com/
